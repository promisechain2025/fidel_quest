# Build-time defaults for every build (web + native). These are public
# values, safe to commit. Override per-environment with .env.local.

# Apple App Store numeric app id (from App Store Connect). Enables the
# in-app Gift flow and is the default buy link for the web trial.
VITE_APPLE_APP_ID=6789703688

# Optional override for the web trial's "Buy the app" button. When unset,
# buyUrl() falls back to the App Store page derived from the id above.
# Set this to a smart link once the Play listing exists too.
# VITE_BUY_URL=
